{
  "name": "comment-novel",
  "displayName": "CommentNovel",
  "description": "在 VS Code 中伪装成代码注释阅读小说",
  "version": "0.1.6",
  "publisher": "comment-novel",
  "author": {
    "name": "CommentNovel"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/comment-novel/comment-novel-vscode"
  },
  "bugs": {
    "url": "https://github.com/comment-novel/comment-novel-vscode/issues"
  },
  "homepage": "https://github.com/comment-novel/comment-novel-vscode#readme",
  "keywords": [
    "novel",
    "reading",
    "comments",
    "disguise",
    "code",
    "fun",
    "productivity"
  ],
  "categories": [
    "Other"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:commentNovel.sidebar",
    "onCommand:CommentNovel.importNovel",
    "onCommand:CommentNovel.openFakeCode",
    "onCommand:CommentNovel.openSettings",
    "onCommand:CommentNovel.resetProgress",
    "onCommand:CommentNovel.previousPage",
    "onCommand:CommentNovel.nextPage"
  ],
  "contributes": {
    "commands": [
      {
        "command": "CommentNovel.previousPage",
        "title": "上一页",
        "category": "CommentNovel"
      },
      {
        "command": "CommentNovel.nextPage",
        "title": "下一页",
        "category": "CommentNovel"
      },
      {
        "command": "CommentNovel.importNovel",
        "title": "导入小说",
        "category": "CommentNovel"
      },
      {
        "command": "CommentNovel.openFakeCode",
        "title": "打开伪装代码",
        "category": "CommentNovel"
      },
      {
        "command": "CommentNovel.resetProgress",
        "title": "重置阅读进度",
        "category": "CommentNovel"
      },
      {
        "command": "CommentNovel.openSettings",
        "title": "打开设置",
        "category": "CommentNovel",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "CommentNovel.previousPage",
          "when": "false"
        },
        {
          "command": "CommentNovel.nextPage",
          "when": "false"
        },
        {
          "command": "CommentNovel.openSettings",
          "when": "false"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "commentNovel",
          "title": "CommentNovel",
          "icon": "images/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "commentNovel": [
        {
          "type": "webview",
          "id": "commentNovel.sidebar",
          "name": "CommentNovel"
        }
      ]
    },
    "configuration": {
      "title": "CommentNovel",
      "properties": {
        "commentNovel.novelDirectory": {
          "type": "string",
          "default": "",
          "description": "读取小说时默认打开的目录路径。留空时使用 VS Code 默认位置。"
        },
        "commentNovel.language": {
          "type": "string",
          "default": "typescript",
          "enum": [
            "typescript",
            "javascript",
            "python",
            "java",
            "cpp",
            "go"
          ],
          "enumDescriptions": [
            "TypeScript (.ts)",
            "JavaScript (.js)",
            "Python (.py)",
            "Java (.java)",
            "C++ (.cpp)",
            "Go (.go)"
          ],
          "description": "用于将小说内容伪装成代码的编程语言。"
        },
        "commentNovel.wordsPerComment": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 200,
          "description": "每行代码注释中嵌入的小说字符数。"
        },
        "commentNovel.commentEveryLines": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 50,
          "description": "每 N 行生成的代码插入一条小说注释。"
        },
        "commentNovel.pageSize": {
          "type": "number",
          "default": 160,
          "minimum": 30,
          "maximum": 1000,
          "description": "每页的代码行数。"
        },
        "commentNovel.noiseCommentRatio": {
          "type": "number",
          "default": 0.15,
          "minimum": 0,
          "maximum": 1,
          "description": "混入的虚假技术注释比例，使代码看起来更真实。"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "prepackage": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "iconv-lite": "^0.6.3"
  }
}
